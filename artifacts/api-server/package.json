{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed:admin": "node ./build-seed.mjs && node --enable-source-maps ./dist/seed-admin.mjs",
    "seed:demos": "node ./build-seed-demos.mjs && node --enable-source-maps ./dist/seed-demo-profiles.mjs"
  },
  "dependencies": {
    "@clerk/express": "^2.1.32",
    "@clerk/shared": "^4.22.0",
    "@google-cloud/storage": "^7.19.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-anthropic-ai": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "google-auth-library": "^10.6.2",
    "http-proxy-middleware": "^3.0.5",
    "jose": "^6.2.3",
    "pino": "^9",
    "pino-http": "^10",
    "razorpay": "^2.9.6",
    "stripe": "^22.0.0",
    "web-push": "^3.6.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
